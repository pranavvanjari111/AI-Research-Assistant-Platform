# LLM provider -- pick ONE (leave the other blank or delete it):
#
# Option A: OpenAI (paid, best quality)
OPENAI_API_KEY=""
#
# Option B: Hugging Face (free). Get a token at
# https://huggingface.co/settings/tokens (a "read" token is enough).
# Embeddings run 100% locally and don't need this token at all --
# it's only used for chat generation.
HUGGINGFACEHUB_API_TOKEN=""
# HF_CHAT_MODEL="HuggingFaceH4/zephyr-7b-beta"
# HF_EMBEDDING_MODEL="sentence-transformers/all-MiniLM-L6-v2"

# MongoDB Atlas connection string (used for user accounts + chat history).
# Example: mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=""
MONGODB_DB_NAME="ai_research_assistant"

# Auth
# Generate a strong secret, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY="change-this-to-a-long-random-secret"
JWT_ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Optional overrides (defaults are fine for local dev)
# DEFAULT_LLM=gpt-4o-mini
# DEFAULT_EMBEDDING_MODEL=text-embedding-3-small
# DEFAULT_RETRIEVER=similarity
# DEFAULT_TOP_K=5
# DEFAULT_TEMPERATURE=0.2
